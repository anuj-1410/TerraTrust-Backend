# Firebase Authentication
FIREBASE_PROJECT_ID=[firebase-project-id]

# Supabase
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=[service_role_key]
DATABASE_URL=postgresql+asyncpg://postgres:[db-password]@[host]:5432/postgres

# Google credentials via local files or Render secret files
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json
GEE_PROJECT_ID=[gee-cloud-project-id]
GEE_CREDENTIALS_PATH=./secrets/gee-service-account.json
CLOUD_VISION_CREDENTIALS_PATH=./secrets/cloud-vision-service-account.json

# Legacy shared Google fallback (optional, only for older local setups)
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# NASA NISAR
NASA_EARTHDATA_USERNAME=[username]
NASA_EARTHDATA_PASSWORD=[password]
NISAR_PRODUCTION_READY=false

# Blockchain
ADMIN_WALLET_PRIVATE_KEY=[private key]
ADMIN_WALLET_ADDRESS=[public address]
ALCHEMY_POLYGON_AMOY_URL=https://polygon-amoy.g.alchemy.com/v2/[key]
CONTRACT_ADDRESS=[deployed contract address — filled after Section 7]

# IPFS
PINATA_JWT=[jwt]
PINATA_GATEWAY_URL=[your-gateway].mypinata.cloud

# PolygonScan
POLYGONSCAN_API_KEY=[key]

# Government APIs
LGD_API_BASE=http://115.124.105.220/API  # Maharashtra LGD API base URL

# App Config
ENVIRONMENT=development        # or production
WEB_CORS_ORIGINS=http://localhost:8081    # Optional comma-separated web origins
REDIS_URL=redis://localhost:6379/0   # Update to cloud Redis URL for production 
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=